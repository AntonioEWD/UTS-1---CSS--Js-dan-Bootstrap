    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Mengambil elemen tombol dan area penampung
const btnOke1 = document.getElementById('btnOkeTahap1');
const areaDinamis = document.getElementById('areaDinamis');

// Variabel global (object) untuk menyimpan data user
let dataUser = {
    bahasa: [],
    hobi: []
};

// ================= TAHAP 1 =================
btnOke1.addEventListener('click', function () {
    // 1. Ambil nilai angka dari inputan tahap 1
    dataUser.nama = document.getElementById('inputNama').value;
    dataUser.alamat = document.getElementById('inputAlamat').value;
    dataUser.email = document.getElementById('inputEmail').value;
    dataUser.jmlBahasa = parseInt(document.getElementById('jmlBahasa').value);
    dataUser.jmlHobi = parseInt(document.getElementById('jmlHobi').value);

    // Validasi sederhana
    if (!dataUser.jmlBahasa || !dataUser.jmlHobi) {
        alert("Harap isi semua data dengan benar!");
        return;
    }

    // 2. Sembunyikan form tahap 1 agar rapi
    document.getElementById('formAwal').style.display = 'none';

    // 3. Merakit HTML baru untuk isian Bahasa dan Hobi
    let htmlTahap2 = '<h4 class="text-center mb-4">Masukkan Nama Bahasa & Hobi</h4>';

    for (let i = 1; i <= dataUser.jmlBahasa; i++) {
        htmlTahap2 += `
            <div class="mb-2">
                <label class="form-label">Bahasa ${i}:</label>
                <input type="text" class="form-control" id="namaBahasa${i}" required>
            </div>
        `;
    }

    htmlTahap2 += '<hr>';

    for (let i = 1; i <= dataUser.jmlHobi; i++) {
        htmlTahap2 += `
            <div class="mb-2">
                <label class="form-label">Hobi ${i}:</label>
                <input type="text" class="form-control" id="namaHobi${i}" required>
            </div>
        `;
    }

    htmlTahap2 += '<button type="button" class="btn btn-success w-100 mt-3" id="btnOkeTahap2">Oke</button>';
    areaDinamis.innerHTML = htmlTahap2;

    // Panggil fungsi Tahap 2
    setupTahap2();
});

// ================= TAHAP 2 =================
function setupTahap2() {
    const btnOke2 = document.getElementById('btnOkeTahap2');
    btnOke2.addEventListener('click', function () {
        
        // 1. Simpan isian bahasa ke array
        dataUser.bahasa = [];
        for (let i = 1; i <= dataUser.jmlBahasa; i++) {
            dataUser.bahasa.push(document.getElementById('namaBahasa' + i).value);
        }

        // 2. Simpan isian hobi ke array
        dataUser.hobi = [];
        for (let i = 1; i <= dataUser.jmlHobi; i++) {
            dataUser.hobi.push(document.getElementById('namaHobi' + i).value);
        }

        // 3. Buat Radio Button (Bahasa) dan Checkbox (Hobi)
        let htmlTahap3 = '<h4 class="text-center mb-4">Pilihan Bahasa & Hobi</h4>';
        
        // --- Radio Button Bahasa ---
        htmlTahap3 += '<div class="mb-3"><label class="form-label fw-bold">Pilihan Bahasa :</label>';
        dataUser.bahasa.forEach((bhs, index) => {
            htmlTahap3 += `
            <div class="form-check">
                <input class="form-check-input" type="radio" name="radioBahasa" id="radioBhs${index}" value="${bhs}">
                <label class="form-check-label" for="radioBhs${index}">${bhs}</label>
            </div>`;
        });
        htmlTahap3 += '</div>';

        // --- Checkbox Hobi ---
        htmlTahap3 += '<div class="mb-3"><label class="form-label fw-bold">Pilihan Hobi :</label>';
        dataUser.hobi.forEach((hb, index) => {
            htmlTahap3 += `
            <div class="form-check">
                <input class="form-check-input cek-hobi" type="checkbox" id="cekHobi${index}" value="${hb}">
                <label class="form-check-label" for="cekHobi${index}">${hb}</label>
            </div>`;
        });
        htmlTahap3 += '</div>';

        htmlTahap3 += '<button type="button" class="btn btn-warning w-100 mt-3" id="btnOkeTahap3">OK</button>';
        areaDinamis.innerHTML = htmlTahap3;

        // Panggil fungsi Tahap 3
        setupTahap3();
    });
}

// ================= TAHAP 3 (HASIL AKHIR) =================
function setupTahap3() {
    const btnOke3 = document.getElementById('btnOkeTahap3');
    btnOke3.addEventListener('click', function() {
        
        // Ambil bahasa yang dipilih (hanya satu)
        let bahasaTerpilih = "";
        let radioBhs = document.getElementsByName('radioBahasa');
        for(let radio of radioBhs) {
            if(radio.checked) {
                bahasaTerpilih = radio.value;
                break;
            }
        }

        // Ambil hobi yang dipilih (bisa lebih dari satu)
        let hobiTerpilih = [];
        let cekHobi = document.querySelectorAll('.cek-hobi:checked'); 
        cekHobi.forEach(cek => {
            hobiTerpilih.push(cek.value);
        });

        // Tampilkan Hasil Akhir pakai Alert / Card Bootstrap
        let htmlHasil = `
            <div class="alert alert-info mt-4">
                <h4 class="alert-heading text-center">Pengumpulan UTS</h4>
                <hr>
                <p>Hallo, nama saya <strong>${dataUser.nama}</strong>, alamat <strong>${dataUser.alamat}</strong>, email <strong>${dataUser.email}</strong> saya mempunyai <strong>${dataUser.jmlBahasa}</strong> pilihan Bahasa yaitu <strong>${dataUser.bahasa.join(', ')}</strong>, dan saya memilih <strong>${bahasaTerpilih}</strong>.</p>
                <p>Saya juga mempunyai <strong>${dataUser.jmlHobi}</strong> pilihan Hobi yaitu <strong>${dataUser.hobi.join(', ')}</strong>, dan saya memilih <strong>${hobiTerpilih.join(', ')}</strong>.</p>
            </div>
        `;

        areaDinamis.innerHTML = htmlHasil;
    });
}
    </script>
